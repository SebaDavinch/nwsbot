DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: for faster local command updates in one guild
DISCORD_GUILD_ID=

# Optional: admin roles that can use admin commands (comma-separated role IDs)
ADMIN_ROLE_IDS=1397527647675879444,1397529397665333318,1456984642602275053

# Optional: enables /vamsys-* commands
VAMSYS_CLIENT_ID=
VAMSYS_CLIENT_SECRET=
VAMSYS_API_SCOPE=
PILOT_API_CLIENT_ID=
PILOT_API_BASE=https://vamsys.io/api/v3/pilot

# Optional: shared auth store and website URLs for booking management buttons
AUTH_STORAGE_FILE=
WEBSITE_BASE_URL=https://vnws.org
PILOT_BOOKINGS_URL=https://vnws.org/dashboard?tab=bookings

# Optional: explicit Python interpreter for Pillow profile card generation
PYTHON_EXECUTABLE=

# Optional: Live flights feed auto-post channel and update period
LIVE_FEED_CHANNEL_ID=1456988328388985003
LIVE_FEED_INTERVAL_MS=120000

# Optional: PIREP review alerts (defaults to admin channel 1405161495368699914)
PIREP_REVIEW_CHANNEL_ID=
PIREP_REVIEW_INTERVAL_MS=60000
PIREP_REVIEW_RECENT_LIMIT=100
PIREP_REVIEW_PENDING_WINDOW_MS=43200000
# Optional: base URL for clickable PIREP links in review alerts
PIREP_WEB_BASE_URL=https://vamsys.io/pireps

# Optional: ticket system channels/categories
TICKET_CATEGORY_ID=
TICKET_CLOSED_CATEGORY_ID=
TICKET_LOG_CHANNEL_ID=
TICKET_ALLOWED_CATEGORIES=general,operations,website,discord,other
TICKET_ALLOWED_LANGUAGES=ru,en
